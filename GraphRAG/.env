# Neo4j Security
NEO4J_URI = "bolt://0.0.0.0:7687"
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=SecurePassword_123!

# Neo4j Performance Tuning
# Heap size (Nên cấu hình tuỳ vào RAM server, không quá 32GB)
NEO4J_HEAP_INITIAL_SIZE=1G
NEO4J_HEAP_MAX_SIZE=2G

# Pagecache (Dùng để cache Graph vào RAM, giúp query siêu nhanh)
NEO4J_PAGECACHE_SIZE=1G

# Cấu hình IP bind (Bảo mật: đổi thành 127.0.0.1 nếu chạy qua Nginx, 0.0.0.0 nếu muốn truy cập thẳng)
NEO4J_BIND_ADDRESS=0.0.0.0
# Cấu hình Ollama LLM nội bộ
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="gemma2:27b"
ollama pull qwen2.5:14b && ollama pull nomic-embed-text
